# GeoTrave Environment Configuration Example
# Copy this file to .env and fill in your actual API keys and preferences.

# --- 全局基础大模型配置 ---
# 只要配置这三个，所有的 Agent（分析师、研究员、路由等）默认都会使用这一套配置。
GLOBAL_MODEL_API_KEY=your_global_api_key_here
GLOBAL_MODEL_BASE_URL=https://api.deepseek.com
GLOBAL_MODEL_ID=deepseek-chat

# ==============================================================================
# --- 单节点独立配置 (按需开启) ---
# 如果您想为特定的节点覆盖基础配置（例如让研究员使用模型B），只需解开对应模块的注释即可。
# ==============================================================================

# --- Analyzer (分析师) 模型配置 ---
# 负责提取用户需求、完善画像。建议使用推理能力较强的模型。
# ANALYZER_MODEL_API_KEY=your_analyzer_api_key_here
# ANALYZER_MODEL_BASE_URL=https://api.deepseek.com
# ANALYZER_MODEL_ID=deepseek-chat

# --- Researcher (研究员) 专属模型配置 ---
# RESEARCHER_MODEL_API_KEY=your_researcher_api_key_here
# RESEARCHER_MODEL_BASE_URL=https://generativelanguage.googleapis.com/v1beta/openai
# RESEARCHER_MODEL_ID=gemini-1.5-flash

# --- Planner (规划师) 专属模型配置 (预留) ---
# 负责最终行程生成。
# PLANNER_MODEL_API_KEY=your_planner_api_key_here
# PLANNER_MODEL_BASE_URL=https://api.openai.com/v1
# PLANNER_MODEL_ID=gpt-4o

# --- Router (网关) 专属模型配置 ---
# ROUTER_MODEL_API_KEY=your_router_api_key_here
# ROUTER_MODEL_BASE_URL=https://api.deepseek.com
# ROUTER_MODEL_ID=deepseek-chat

# --- PostGIS 空间数据库连接 ---
POSTGIS_DSN=postgresql://geotrave:geotrave_dev@localhost:5432/geotrave

# --- 系统基础配置 ---
# 日志等级：DEBUG (开发详情), INFO (业务流转), WARNING, ERROR
LOG_LEVEL=INFO

# 搜索工具配置 (目前支持 DuckDuckGo，无需 API Key)

# 超时设置 (秒)
LLM_TIMEOUT=60

